# Environment configuration — copy what you need into .env.local for local work.
#
# Precedence, highest first:
#   1. real environment variables (Railway sets these in production)
#   2. .env.local   — your machine only, gitignored, never committed
#   3. .env         — shared/default file, also gitignored
#
# DEV-002 SAFEGUARD
# -----------------
# Outside production, the server refuses to start if DATABASE_URL points at a
# remote host (server/databaseGuard.js). This exists because `.env` has
# historically carried the production Railway URL, which meant `npm run dev`
# attached to production Postgres with write access.
#
# For local development, create `.env.local` with ONE of:
#
#   # A local Postgres:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/repmail_dev
#
#   # Or no database at all — server/db.js falls back to in-memory storage,
#   # which is enough for most frontend and Resource Center work:
#   DATABASE_URL=
#
# If you genuinely need to reach the remote database from a dev machine, make it
# deliberate rather than accidental:
#
#   ALLOW_REMOTE_DB=1 npm run dev
#
# Note that `npm start` sets NODE_ENV=production and therefore bypasses the
# guard by design. Use `npm run dev` for local work.

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
DATABASE_URL=

# Set to 1/true/yes only when you intend to reach a remote database from a
# non-production process. Leave unset otherwise.
# ALLOW_REMOTE_DB=

# ── Optional integrations ────────────────────────────────────────────────────
# Every one of these is optional locally; the server degrades gracefully and
# logs which subsystem is disabled at startup.

# Redis — absent means the BullMQ worker is disabled and campaigns run inline.
# REDIS_URL=

# AWS SES — absent means sending is disabled.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# SES_SEND_RATE_MS=75

# Razorpay — absent means payments are disabled.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# OpenAI — powers AI personalization and spam analysis.
# OPENAI_API_KEY=

# Google OAuth — absent means only local login works.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Observability and operations.
# SENTRY_DSN=
# RECOVERY_EMAIL=
# IP_HASH_SALT=
