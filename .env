# EmailFlow Pro Environment Variables
# ====================================
# 
# DEV MODE: Leave these empty or as placeholders
# The app will run with in-memory storage automatically.
#
# PRODUCTION MODE: Fill in real values
# The app will automatically switch to real PostgreSQL.

# Database (leave empty for DEV mode)
DATABASE_URL=

# Server Configuration
NODE_ENV=development
PORT=5000

# Admin Defaults (used when creating root admin)
ADMIN_PASSWORD=changeme123
ADMIN_EMAIL=admin@emailflow.pro

# Session Security (generate a random string for production)
SESSION_SECRET=

# Optional: External Services (not required for DEV mode)
# OPENAI_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRIPE_SECRET_KEY=

